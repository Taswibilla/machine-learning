stack = []

# Push elements
stack.append(10)
stack.append(20)
stack.append(30)

print("Stack:", stack)

# Pop element
stack.pop()
print("After pop:", stack)

# Peek
if stack:
    print("Top element:", stack[-1])

# Check if empty
if len(stack) == 0:
    print("Stack is empty")
else:
    print("Stack is not empty")